  {
    "id": "TC009",
    "title": "Criar novo agendamento a partir de um horário vazio com cliente selecionado",
    "description": "Valida que é possível criar um agendamento selecionando profissional, serviço e cliente e que ele aparece no calendário como Pendente.",
    "category": "Agenda de Horários",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "action",
        "description": "Click the \"Agenda\" option in the main navigation/menu"
      },
      {
        "type": "action",
        "description": "Click an empty time slot in the calendar"
      },
      {
        "type": "action",
        "description": "Select a professional from the professional dropdown/list"
      },
      {
        "type": "action",
        "description": "Select a service from the service dropdown/list"
      },
      {
        "type": "action",
        "description": "Search for a client in the ClientSelect field and select one result"
      },
      {
        "type": "action",
        "description": "Click the \"Save\" button"
      },
      {
        "type": "assertion",
        "description": "Verify the newly created appointment is visible in the calendar"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Pendente\" is visible for the appointment"
      }
    ]
  },
