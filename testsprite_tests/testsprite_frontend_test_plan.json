    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /registro"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Passo 1\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"Teste\" into the \"Nome\" field"
      },
      {
        "type": "action",
        "description": "Type \"teste.sucesso+001@exemplo.com\" into the \"Email\" field"
      },
      {
        "type": "action",
        "description": "Click on \"Próximo\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Nome da sua barbearia\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"Barbearia Sucesso 001\" into the \"Nome da sua barbearia\" field"
      },
      {
        "type": "action",
        "description": "Click on \"Finalizar Cadastro\""
      }
    ]
  },
